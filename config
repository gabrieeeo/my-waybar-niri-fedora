[
  {
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 5,
    "modules-left": [
      "hyprland/workspaces",
      "wlr/taskbar"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "idle_inhibitor",
      "temperature",
      "cpu",
      "memory",
      "network",
      "pulseaudio",
      "custom/power",
      "tray"
    ],
    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "focused": "тЧП",
        "active": "тЧП",
        "default": "тЧЛ",
        "empty": "тЧЛ"
      }
    },
    "wlr/taskbar": {
      "format": "{title:.16}",
      "tooltip-format": "{title}",
      "all-outputs": true,
      "on-click": "activate",
      "on-click-middle": "close"
    },
    "mpris": {
      "format": "{status_icon} {dynamic}",
      "format-paused": "{status_icon} {dynamic}",
      "format-stopped": "",
      "dynamic-len": 40,
      "status-icons": {
        "playing": "яБЛ",
        "paused": "яБМ",
        "stopped": "яБН"
      }
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "яБо",
        "deactivated": "яБ░"
      }
    },
    "tray": {
      "icon-size": 16,
      "show-passive-items": true,
      "spacing": 10
    },
    "clock": {
      "format": "{:%A %B %d %H:%M}",
      "on-click": "env GSK_RENDERER=gl /home/gabriel/.config/waybar/scripts/calendar-popup.py",
      "tooltip": false
    },
    "cpu": {
      "interval": 2,
      "format": "яЛЫ  {usage}%"
    },
    "memory": {
      "interval": 2,
      "format": "яГЙ {}%"
    },
    "temperature": {
      "interval": 2,
      "hwmon-path": [
        "/sys/class/hwmon/hwmon1/temp1_input",
        "/sys/class/hwmon/hwmon0/temp1_input"
      ],
      "critical-threshold": 80,
      "format-critical": "яЛЙ {temperatureC}┬░C",
      "format": "яЛЙ {temperatureC}┬░C"
    },
    "network": {
      "format-wifi": "яЗл {essid} ({signalStrength}%)",
      "format-ethernet": "яГБ {ifname}",
      "tooltip-format": "яГБ {ifname} via {gwaddr}",
      "format-linked": "яГБ {ifname} (No IP)",
      "format-disconnected": "яБ▒ {ifname}",
      "on-click": "nm-connection-editor"
    },
    "pulseaudio": {
      "scroll-step": 5,
      "format": "{icon}  {volume}% {format_source}",
      "format-bluetooth": "яКФ {icon} {volume}% {format_source}",
      "format-bluetooth-muted": "яЪй яКФ {icon} {format_source}",
      "format-muted": "яЪй  {format_source}",
      "format-source": "яД░ {volume}%",
      "format-source-muted": "яД▒",
      "format-icons": {
        "default": [
          "яАж",
          "яАз",
          "яАи"
        ]
      },
      "on-click": "pavucontrol"
    },
    "custom/power": {
      "format": "тП╗",
      "tooltip": false,
      "on-click": "env GSK_RENDERER=gl /home/gabriel/.config/waybar/scripts/power-menu.py"
    }
  }
]
